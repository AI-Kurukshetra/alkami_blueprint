{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "es2022"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "baseUrl": ".",
    "paths": {
      "@banking/config/*": ["packages/config/src/*"],
      "@banking/database/*": ["packages/database/src/*"],
      "@banking/types/*": ["packages/types/src/*"],
      "@banking/ui/*": ["packages/ui/src/*"],
      "@banking/utils/*": ["packages/utils/src/*"]
    }
  }
}

