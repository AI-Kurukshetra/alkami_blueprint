{
  "name": "digital-banking-platform",
  "private": true,
  "packageManager": "pnpm@9.15.2",
  "scripts": {
    "dev": "next dev",
    "build": "corepack pnpm -r --filter \"@banking/*\" --if-present run build && next build",
    "lint": "corepack pnpm -r --filter \"@banking/*\" --if-present run lint && next lint",
    "typecheck": "corepack pnpm -r --filter \"@banking/*\" --if-present run typecheck && tsc --noEmit",
    "test": "corepack pnpm -r --filter \"@banking/*\" --if-present run test && vitest run --passWithNoTests",
    "test:e2e": "corepack pnpm exec playwright test",
    "verify:workspace": "node scripts/verify-workspace.mjs",
    "supabase:start": "npx supabase start",
    "supabase:stop": "npx supabase stop",
    "supabase:db:reset": "npx supabase db reset",
    "deploy:vercel": "vercel --prod"
  },
  "dependencies": {
    "@banking/config": "workspace:*",
    "@banking/database": "workspace:*",
    "@banking/types": "workspace:*",
    "@banking/ui": "workspace:*",
    "@banking/utils": "workspace:*",
    "@supabase/ssr": "^0.6.1",
    "@supabase/supabase-js": "^2.49.1",
    "@tanstack/react-query": "^5.68.0",
    "next": "^14.2.25",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@types/node": "^22.13.10",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.25",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "turbo": "^2.5.0",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  }
}
